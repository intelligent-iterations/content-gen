# ===========================================
# AI Content Generation APIs
# ===========================================

# Grok API (xAI) - Required for content research and generation
# Get your API key at: https://console.x.ai
XAI_API_KEY=xai-xxxxx

# Replicate (for Seedream-4 image generation)
# Get your API token at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_xxxxx

# Google Gemini (for ingredient extraction)
# Get your API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=xxxxx

# ===========================================
# Social Media Platform APIs
# ===========================================

# TikTok Content Posting API
# Get these from: https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=xxxxx
TIKTOK_CLIENT_SECRET=xxxxx
TIKTOK_ACCESS_TOKEN=xxxxx
TIKTOK_REFRESH_TOKEN=xxxxx
TIKTOK_REDIRECT_URI=http://localhost:3000/callback

# Instagram Graph API
# Get these from: https://developers.facebook.com/
INSTAGRAM_ACCESS_TOKEN=xxxxx
INSTAGRAM_BUSINESS_ACCOUNT_ID=xxxxx

# X (Twitter) API v2
# Get these from: https://developer.twitter.com/
X_BEARER_TOKEN=xxxxx
X_API_KEY=xxxxx
X_API_SECRET=xxxxx
X_ACCESS_TOKEN=xxxxx
X_ACCESS_TOKEN_SECRET=xxxxx

# YouTube Data API
# Get these from: https://console.cloud.google.com/
YOUTUBE_CLIENT_ID=xxxxx
YOUTUBE_CLIENT_SECRET=xxxxx
YOUTUBE_REFRESH_TOKEN=xxxxx

# Pinterest API
# Get these from: https://developers.pinterest.com/
PINTEREST_ACCESS_TOKEN=xxxxx

# Reddit API
# Get these from: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=xxxxx
REDDIT_CLIENT_SECRET=xxxxx
REDDIT_USERNAME=xxxxx
REDDIT_PASSWORD=xxxxx

# ===========================================
# Firebase (for app screenshots)
# ===========================================

# Firebase Admin SDK
# Download service account JSON from Firebase Console
FIREBASE_PROJECT_ID=xxxxx
FIREBASE_STORAGE_BUCKET=xxxxx

# App Check Debug Token (for emulator)
APP_CHECK_DEBUG_TOKEN=xxxxx

# ===========================================
# Optional: Browser Automation Credentials
# ===========================================

# Pinterest (if using Zendriver browser automation instead of API)
PINTEREST_EMAIL=your@email.com
PINTEREST_PASSWORD=yourpassword
